---
import { Icon } from "astro-icon/components";
import { Code } from "astro-expressive-code/components";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getLabelFromExt, getLangFromExt, type CodeFile } from "@utils/code-files";

interface Props {
	codeFile: CodeFile;
}

const MAX_HIGHLIGHT_BYTES = 256 * 1024;
const MAX_HIGHLIGHT_LINES = 5000;
const LARGE_FILE_PREVIEW_LINES = 800;

const { codeFile } = Astro.props;
const lang = getLangFromExt(codeFile.ext);
const typeLabel = getLabelFromExt(codeFile.ext);
const codeLines = codeFile.content.split("\n");
const lines = codeLines.length;
const isLargeFile =
	codeFile.content.length > MAX_HIGHLIGHT_BYTES || lines > MAX_HIGHLIGHT_LINES;
const previewContent = isLargeFile
	? codeLines.slice(0, LARGE_FILE_PREVIEW_LINES).join("\n")
	: codeFile.content;
---

<MainGridLayout title={codeFile.name}>
	<div class="card-base px-6 md:px-9 pt-6 pb-4 mb-4">
		<div class="flex items-center gap-3 mb-4">
			<Icon
				name="material-symbols:code-rounded"
				class="text-[var(--primary)] text-2xl flex-shrink-0"
			/>
			<div class="min-w-0">
				<div class="font-bold text-xl text-90 truncate">
					{codeFile.name}
				</div>
				<div class="text-sm text-50">
					{typeLabel} &middot; {lines} lines
				</div>
			</div>
		</div>
		{
			isLargeFile ? (
				<>
					<div class="mb-4 rounded-xl border border-[var(--line-divider)] bg-[var(--btn-plain-bg-hover)] px-4 py-3 text-sm text-70">
						This generated file is too large for build-time syntax
						highlighting. Showing the first {LARGE_FILE_PREVIEW_LINES} of{" "}
						{lines} lines.
					</div>
					<pre class="overflow-x-auto rounded-xl bg-[#0f111a] p-4 text-sm leading-6 text-[#d7dce8]"><code>{previewContent}</code></pre>
				</>
			) : (
				<Code code={codeFile.content} lang={lang} meta={`title="${codeFile.name}"`} />
			)
		}
	</div>
</MainGridLayout>
