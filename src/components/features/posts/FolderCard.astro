---
import { Icon } from "astro-icon/components";

import Image from "@/components/atoms/Image/Image.astro";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

interface Props {
	name: string;
	href: string;
	count?: number;
	postCount?: number;
	codeFileCount?: number;
	newest?: string;
	image?: string;
	basePath?: string;
}

const {
	name,
	href,
	count,
	postCount,
	codeFileCount = 0,
	newest = "—",
	image = "",
	basePath = "/",
}: Props = Astro.props;

const resolvedPostCount = postCount ?? count ?? 0;
const hasCover = image !== "";
const coverWidth = "28%";
---

<a
	href={href}
	class="card-base flex flex-col-reverse md:flex-col w-full rounded-[var(--radius-large)] overflow-hidden relative group hover:border-[var(--primary)] transition-colors"
>
	<div
		class:list={[
			"pl-6 md:pl-9 pr-6 md:pr-2 pt-6 md:pt-7 pb-6 relative",
			{
				"w-full md:w-[calc(100%_-_3.25rem_-_0.75rem)]": !hasCover,
				"w-full md:w-[calc(100%_-_var(--coverWidth)_-_0.75rem)]": hasCover,
			},
		]}
	>
		<div class="flex items-center gap-3 mb-3">
			<Icon
				name="material-symbols:folder-outline-rounded"
				class="text-[var(--primary)] text-3xl shrink-0"
			/>
			<span class="font-bold text-xl text-90 group-hover:text-[var(--primary)] transition-colors break-all">
				{name}/
			</span>
		</div>
		<div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-50">
			<span>{newest}</span>
			<span>
				{resolvedPostCount === 1
					? `1 ${i18n(I18nKey.postCount)}`
					: `${resolvedPostCount} ${i18n(I18nKey.postsCount)}`}
			</span>
			<span>
				{codeFileCount === 1
					? `1 ${i18n(I18nKey.codeFileCount)}`
					: `${codeFileCount} ${i18n(I18nKey.codeFilesCount)}`}
			</span>
		</div>
	</div>

	{
		hasCover && (
			<div
				class:list={[
					"max-h-[20vh] md:max-h-none mx-4 mt-4 -mb-2 md:mb-0 md:mx-0 md:mt-0",
					"md:w-[var(--coverWidth)] relative md:absolute md:top-3 md:bottom-3 md:right-3 rounded-xl overflow-hidden",
				]}
			>
				<div class="absolute pointer-events-none z-10 w-full h-full bg-black/10 group-hover:bg-black/20 transition" />
				<Image
					src={image}
					basePath={basePath}
					alt={`Cover image of folder ${name}`}
					class="w-full h-full"
					widths={[200, 400, 800]}
					sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
				/>
			</div>
		)
	}

	{
		!hasCover && (
			<div class="!hidden md:!flex btn-regular w-[3.25rem] absolute right-3 top-3 bottom-3 rounded-xl bg-[var(--enter-btn-bg)]">
				<Icon
					name="material-symbols:chevron-right-rounded"
					class="transition text-[var(--primary)] text-4xl mx-auto"
				/>
			</div>
		)
	}
</a>

<style define:vars={{ coverWidth }}></style>
