---
import { getImage } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import path from "node:path";
import { Icon } from "astro-icon/components";
import Comment from "@components/comment/index.astro";
import {
	FolderCard,
	LastModified,
	PostMeta,
	PostNavigation,
	RandomPosts,
	RelatedPosts,
	ShareCard,
} from "@components/features/posts";
import BlogTerminal from "@components/features/posts/BlogTerminal.astro";
import { ReadingTime, WordCount } from "@components/features/posts/atoms";
import PostCard from "@components/features/posts/PostCard.astro";
import CodeViewer from "@components/features/posts/CodeViewer.astro";
import License from "@components/misc/License.astro";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
	getCategoryTree,
	getCategoryCardMeta,
	findCategoryNode,
	getCategoryPathFromId,
} from "@utils/category-tree";
import { getCodeFiles, getCodeFilesInDir, type CodeFile } from "@utils/code-files";
import { getRelatedPosts, getSortedPosts } from "@utils/content-utils";
import { hasCustomPermalink, initPostIdMap } from "@utils/permalink-utils";
import { getPostPublicDescription } from "@utils/post-card-content";
import { buildTerminalFs, getInitialTerminalPath, type TerminalDirectory } from "@utils/terminal-fs";
import {
	getFileDirFromPath,
	removeFileExtension,
	url,
} from "@utils/url-utils";
import {
	licenseConfig,
	permalinkConfig,
	randomPostsConfig,
	relatedPostsConfig,
	shareConfig,
} from "src/config";

import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import Image from "../../components/atoms/Image/Image.astro";
import Encryptor from "../../components/features/auth/Encryptor.astro";
import { profileConfig, siteConfig } from "../../config";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";

export async function getStaticPaths() {
	const blogEntries = await getSortedPosts();
	initPostIdMap(blogEntries);

	const tree = await getCategoryTree();

	const articleSlugs = new Set(
		blogEntries.map((e) => removeFileExtension(e.id)),
	);

	const paths: {
		params: { slug: string };
		props: {
			entry?: CollectionEntry<"posts">;
			directorySlug?: string;
			codeFile?: CodeFile;
		};
	}[] = [];

	for (const entry of blogEntries) {
		const defaultSlug = removeFileExtension(entry.id);

		if (hasCustomPermalink(entry)) {
			paths.push({
				params: { slug: defaultSlug },
				props: { entry },
			});
			continue;
		}

		if (permalinkConfig.enable) {
			paths.push({
				params: { slug: defaultSlug },
				props: { entry },
			});
		} else {
			paths.push({
				params: { slug: defaultSlug },
				props: { entry },
			});

			if (entry.data.alias) {
				let alias = entry.data.alias.replace(/^\/+/, "").replace(/\/+$/, "");
				if (alias.startsWith("posts/")) {
					alias = alias.replace(/^posts\//, "");
				}
				paths.push({
					params: { slug: alias },
					props: { entry },
				});
			}
		}
	}

	function collectDirPaths(nodes: typeof tree) {
		for (const node of nodes) {
			if (!articleSlugs.has(node.fullPath)) {
				paths.push({
					params: { slug: node.fullPath },
					props: { directorySlug: node.fullPath },
				});
			}
			collectDirPaths(node.children);
		}
	}
	collectDirPaths(tree);

	const dirSlugs = new Set(
		paths
			.filter((p) => p.props.directorySlug)
			.map((p) => p.props.directorySlug),
	);

	const codeFiles = getCodeFiles();
	for (const cf of codeFiles) {
		if (articleSlugs.has(cf.id)) continue;
		if (dirSlugs.has(cf.id)) continue;
		paths.push({
			params: { slug: cf.id },
			props: { codeFile: cf },
		});
	}

	return paths;
}

const { entry, directorySlug, codeFile } = Astro.props;
let terminalFs: TerminalDirectory | undefined;

/* ---- directory view ---- */
	let directoryData:
	| {
			slugSegments: string[];
			node: ReturnType<typeof findCategoryNode>;
			dirPosts: Awaited<ReturnType<typeof getSortedPosts>>;
			subcategories: NonNullable<
				ReturnType<typeof findCategoryNode>
			>["children"];
			ancestors: { name: string; path: string }[];
			dirCodeFiles: CodeFile[];
	  }
	| undefined;

if (directorySlug && !entry) {
	const slugSegments = directorySlug.split("/");
	const tree = await getCategoryTree();
	const node = findCategoryNode(tree, slugSegments);
	const allPosts = await getSortedPosts();
	const dirPosts = node
		? allPosts.filter(
				(p) => getCategoryPathFromId(p.id) === directorySlug,
			)
		: [];
	const subcategories = node?.children ?? [];
	const dirCodeFiles = getCodeFilesInDir(directorySlug);

	const ancestors: { name: string; path: string }[] = [];
	let accPath = "";
	for (let i = 0; i < slugSegments.length; i++) {
		accPath = accPath
			? `${accPath}/${slugSegments[i]}`
			: slugSegments[i];
		ancestors.push({ name: slugSegments[i], path: accPath });
	}

	directoryData = {
		slugSegments,
		node,
		dirPosts,
		subcategories,
		ancestors,
		dirCodeFiles,
	};
	terminalFs = await buildTerminalFs();
}

/* ---- article view ---- */
	let articleData:
	| {
			Content: any;
			headings: any;
			remarkPluginFrontmatter: any;
			relatedPosts: any[];
			ogCoverUrl: string | undefined;
			posterCoverUrl: string | undefined;
			posterAvatarUrl: string | undefined;
			isEncrypted: boolean;
			publicDescription: string;
			jsonLd: Record<string, unknown>;
	  }
	| undefined;

if (entry) {
	const { Content, headings } = await render(entry);
	const { remarkPluginFrontmatter } = await render(entry);

	const relatedPosts = relatedPostsConfig.enable
		? await getRelatedPosts(entry, relatedPostsConfig.maxCount)
		: [];

	let ogCoverUrl: string | undefined;
	let posterCoverUrl = entry.data.image;

	if (entry.data.image) {
		const isLocal = !(
			entry.data.image.startsWith("/") ||
			entry.data.image.startsWith("http") ||
			entry.data.image.startsWith("https") ||
			entry.data.image.startsWith("data:")
		);
		if (isLocal) {
			const basePath = getFileDirFromPath(entry.filePath || "");
			const files = import.meta.glob<ImageMetadata>(
					"../../**/*.{png,jpg,jpeg,webp,gif,svg,avif}",
					{ import: "default" },
				);
			const normalizedPath = path
				.normalize(path.join("../../", basePath, entry.data.image))
				.replace(/\\/g, "/");
			const file = files[normalizedPath];
			if (file) {
				const img = await file();
				posterCoverUrl = img.src;

				const ogImage = await getImage({
					src: img,
					width: 1200,
					format: "jpeg",
					quality: 80,
				});
				ogCoverUrl = ogImage.src;
			}
		} else if (entry.data.image.startsWith("http")) {
			ogCoverUrl = entry.data.image;

			try {
				const response = await fetch(entry.data.image);
				const arrayBuffer = await response.arrayBuffer();
				const base64 = Buffer.from(arrayBuffer).toString("base64");
				const contentType =
					response.headers.get("content-type") || "image/jpeg";
				posterCoverUrl = `data:${contentType};base64,${base64}`;
			} catch {
				posterCoverUrl = entry.data.image;
			}
		} else {
			ogCoverUrl = entry.data.image;
		}
	}

	let posterAvatarUrl = profileConfig.avatar;
	if (profileConfig.avatar) {
		const isLocal = !(
			profileConfig.avatar.startsWith("/") ||
			profileConfig.avatar.startsWith("http") ||
			profileConfig.avatar.startsWith("https") ||
			profileConfig.avatar.startsWith("data:")
		);
		if (isLocal) {
			const files = import.meta.glob<ImageMetadata>(
					"../../**/*.{png,jpg,jpeg,webp,gif,svg,avif}",
					{ import: "default" },
				);
			const normalizedPath = path
				.normalize(path.join("../../", profileConfig.avatar))
				.replace(/\\/g, "/");
			const file = files[normalizedPath];
			if (file) {
				const img = await file();
				posterAvatarUrl = img.src;
			}
		}
	}

	const isEncrypted = !!(entry.data.encrypted && entry.data.password);
	const publicDescription = getPostPublicDescription(
		entry.data,
		entry.data.title,
	);

	const jsonLd = {
		"@context": "https://schema.org",
		"@type": "BlogPosting",
		headline: entry.data.title,
		description: publicDescription,
		keywords: entry.data.tags,
		author: {
			"@type": "Person",
			name: profileConfig.name,
			url: Astro.site,
		},
		datePublished: formatDateToYYYYMMDD(entry.data.published),
		inLanguage: entry.data.lang
			? entry.data.lang.replace("_", "-")
			: siteConfig.lang.replace("_", "-"),
	};

	articleData = {
		Content,
		headings,
		remarkPluginFrontmatter,
		relatedPosts,
		ogCoverUrl,
		posterCoverUrl,
		posterAvatarUrl,
		isEncrypted,
		publicDescription,
		jsonLd,
	};
}
---

{
	codeFile ? (
		<CodeViewer codeFile={codeFile} />
	) : directoryData ? (
		<MainGridLayout title={directoryData.slugSegments.join("/")}>
			<div class="card-base px-6 md:px-9 pt-6 pb-4 mb-4">
				<nav
					class="flex items-center gap-1.5 text-sm text-50 mb-4"
					aria-label="breadcrumb"
				>
					<a
						href={url("/posts/")}
						class="hover:text-[var(--primary)] transition-colors"
					>
						{i18n(I18nKey.home)}
					</a>
					{
						directoryData.ancestors.map((anc) => (
							<>
								<span class="text-30">/</span>
								<a
									href={url(
										`/posts/${anc.path}/`,
									)}
									class="hover:text-[var(--primary)] transition-colors"
								>
									{anc.name}
								</a>
							</>
						))
					}
				</nav>

				{
					terminalFs && (
						<BlogTerminal
							fsTree={terminalFs}
							currentPath={getInitialTerminalPath(directorySlug)}
						/>
					)
				}

				{
					(directoryData.subcategories.length > 0 ||
						directoryData.dirPosts.length > 0 ||
						directoryData.dirCodeFiles.length > 0) ? (
						<div class="flex flex-col gap-4">
							{directoryData.subcategories.map((sub) => {
								const { newestPost, cover } =
									getCategoryCardMeta(sub);
								return (
									<FolderCard
										name={sub.name}
										href={url(
											`/posts/${sub.fullPath}/`,
										)}
										count={sub.count}
										newest={
											newestPost
												? newestPost.data.published
														.toISOString()
														.slice(0, 10)
												: "—"
										}
										image={cover?.image || ""}
										basePath={cover?.basePath || ""}
									/>
								);
							})}
							{directoryData.dirPosts.map(
								(post) => (
									<PostCard entry={post} />
								),
							)}
							{directoryData.dirCodeFiles.map(
								(cf) => (
									<a
										href={url(
											`/posts/${cf.id}/`,
										)}
										class="card-base flex flex-col w-full rounded-[var(--radius-large)]
											overflow-hidden relative group
											hover:border-[var(--primary)] transition-colors"
									>
										<div class="px-6 md:px-9 py-5">
											<div class="flex items-center gap-3 mb-2">
												<Icon
													name="material-symbols:code-rounded"
													class="text-[var(--primary)] text-3xl"
												/>
												<span class="font-bold text-xl text-90 group-hover:text-[var(--primary)] transition-colors">
													{cf.name}
												</span>
											</div>
											<div class="flex items-center gap-4 text-sm text-50">
												<span>
													{cf.content.split(
														"\n",
													).length} lines
												</span>
												<span>
													{cf.ext.replace(
														".",
														"",
													).toUpperCase()}
												</span>
											</div>
										</div>
									</a>
								),
							)}
						</div>
					) : (
						<div class="text-center text-50 py-8">
							{i18n(I18nKey.notFound)}
						</div>
					)
				}
			</div>
		</MainGridLayout>
	) : articleData && entry ? (
		<MainGridLayout
			banner={entry.data.image}
			title={entry.data.title}
			description={articleData.publicDescription}
			lang={entry.data.lang}
			setOGTypeArticle={true}
			postSlug={entry.id}
			headings={articleData.headings}
			coverImage={articleData.ogCoverUrl}
			publishedDate={entry.data.published}
			category={entry.data.category || undefined}
			wordCount={articleData.remarkPluginFrontmatter.words}
		>
			<script
				is:inline
				slot="head"
				type="application/ld+json"
				set:html={JSON.stringify(articleData.jsonLd)}
			/>
			<script>
				import("../../scripts/right-sidebar-layout.js");
			</script>
			<div
				class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4"
			>
				<div
					id="post-container"
					class:list={[
						"card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full ",
						{},
					]}
				>
					<div
						class="flex flex-row text-black/30 dark:text-white/30 gap-5 mb-3 transition onload-animation"
					>
						<div class="flex flex-row items-center">
							<WordCount
								words={
									articleData
										.remarkPluginFrontmatter
										.words
								}
								variant="card"
							/>
						</div>
						<div class="flex flex-row items-center">
							<ReadingTime
								minutes={
									articleData
										.remarkPluginFrontmatter
										.minutes
								}
								variant="card"
							/>
						</div>
					</div>

					<div class="relative onload-animation">
						<div
							data-pagefind-body
							data-pagefind-weight="10"
							data-pagefind-meta="title"
							class="transition w-full block font-bold mb-3
							text-3xl md:text-[2.25rem]/[2.75rem]
							text-black/90 dark:text-white/90
							md:before:w-1 before:h-5 before:rounded-md before:bg-[var(--primary)]
							before:absolute before:top-[0.75rem] before:left-[-1.125rem]"
						>
							{entry.data.title}
						</div>
					</div>

					<div class="onload-animation">
						<PostMeta
							className="mb-5"
							published={entry.data.published}
							updated={entry.data.updated}
							tags={entry.data.tags}
							category={
								entry.data.category || undefined
							}
							id={entry.id}
							showEncrypted={
								articleData.isEncrypted
							}
						/>
						{
							(!entry.data.image ||
								(entry.data.image &&
									!siteConfig
										.showCoverInContent)) && (
								<div class="mt-4 border-[var(--line-divider)] border-dashed border-b-[1px] mb-5" />
							)
						}
					</div>

					{
						entry.data.image &&
							siteConfig.showCoverInContent && (
								<>
									<div class="mt-4" />
									<Image
										id="post-cover"
										src={entry.data.image}
										basePath={getFileDirFromPath(
											entry.filePath ||
												"",
										)}
										class="mb-8 rounded-xl banner-container onload-animation"
										widths={[
											640,
											1024,
											1536,
											2048,
										]}
										sizes="(max-width: 768px) 100vw, (max-width: 1200px) 80vw, 1200px"
									/>
								</>
							)
					}

					{
						articleData.isEncrypted ? (
							<Encryptor
								password={entry.data.password}
								slug={entry.id}
								hint={
									entry.data.passwordHint
								}
							>
								<Markdown class="mb-6 markdown-content onload-animation">
									<articleData.Content />
								</Markdown>
							</Encryptor>
						) : (
							<Markdown class="mb-6 markdown-content onload-animation">
								<articleData.Content />
							</Markdown>
						)
					}

					{
						shareConfig.enable && (
							<ShareCard
								class:list={[
									{
										"encrypted-hidden":
											articleData.isEncrypted,
									},
								]}
								title={entry.data.title}
								author={entry.data.author}
								description={
									articleData.publicDescription
								}
								pubDate={formatDateToYYYYMMDD(
									entry.data.published,
								)}
								coverImage={
									articleData.posterCoverUrl
								}
								url={Astro.url.toString()}
								siteTitle={
									siteConfig.title
								}
								avatar={
									articleData.posterAvatarUrl
								}
							/>
						)
					}

					{
						licenseConfig.enable && (
							<div
								id="license-component"
								class:list={[
									"encrypted-hidden-wrapper",
									{
										"encrypted-hidden":
											articleData.isEncrypted,
									},
								]}
							>
								<License
									title={
										entry.data.title
									}
									id={entry.id}
									pubDate={
										entry.data
											.published
									}
									author={
										entry.data.author
									}
									sourceLink={
										entry.data
											.sourceLink
									}
									licenseName={
										entry.data
											.licenseName
									}
									licenseUrl={
										entry.data
											.licenseUrl
									}
									class="mb-6 rounded-xl license-container onload-animation"
								/>
							</div>
						)
					}
				</div>

			</div>

			<Comment post={entry} />

			{
				siteConfig.showLastModified && (
					<LastModified
						updatedDate={
							entry.data.updated ||
							entry.data.published
						}
					/>
				)
			}

			<PostNavigation
				prevSlug={entry.data.nextSlug}
				prevTitle={entry.data.nextTitle}
				nextSlug={entry.data.prevSlug}
				nextTitle={entry.data.prevTitle}
			/>

			{
				(relatedPostsConfig.enable ||
					randomPostsConfig.enable) && (
					<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
						{relatedPostsConfig.enable &&
							articleData.relatedPosts.length >
								0 && (
								<RelatedPosts
									relatedPosts={
										articleData.relatedPosts
									}
								/>
							)}
						{randomPostsConfig.enable && (
							<RandomPosts
								excludeIds={[entry.id]}
								maxCount={
									randomPostsConfig.maxCount
								}
							/>
						)}
					</div>
				)
			}
		</MainGridLayout>
	) : null
}
