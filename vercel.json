{
	"buildCommand": "pnpm build",
	"outputDirectory": "dist",
	"installCommand": "pnpm install",
	"framework": "astro",
	"functions": {
		"api/meting.js": {
			"maxDuration": 30,
			"regions": ["hkg1"]
		}
	},
	"headers": [
		{
			"source": "/(BingSiteAuth.xml|google1f718a5572f26c37.html)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "no-cache"
				}
			]
		},
		{
			"source": "/(.*)",
			"headers": [
				{
					"key": "X-Content-Type-Options",
					"value": "nosniff"
				},
				{
					"key": "X-Frame-Options",
					"value": "DENY"
				},
				{
					"key": "X-XSS-Protection",
					"value": "1; mode=block"
				},
				{
					"key": "Referrer-Policy",
					"value": "strict-origin-when-cross-origin"
				}
			]
		},
		{
			"source": "/_astro/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		}
	],
	"cleanUrls": true
}
